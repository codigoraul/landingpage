---
import { Image } from 'astro:assets';
import bgImage from '@images/bg-hero.webp';
import heroCelu from '@images/heroCelu.webp';
---

<section
  class="relative overflow-hidden bg-gradient-to-br from-[#79D8DF] to-white"
  aria-label="Hero principal"
>
  <!-- Fondo (solo desktop) -->
  <div class="pointer-events-none absolute inset-0 hidden lg:block" aria-hidden="true">
    <Image
      src={bgImage}
      alt=""
      widths={[1024, 1440, 1920]}
      sizes="100vw"
      quality={70}
      class="absolute inset-0 h-full w-full object-cover"
      loading="eager"
      decoding="sync"
      fetchpriority="high"
      format="webp"
    />
    <div class="absolute inset-0 bg-gradient-to-b from-transparent to-white/30"></div>
  </div>

  <div class="container-page relative z-10 grid gap-10 py-14 md:py-20 lg:grid-cols-12 lg:gap-8 lg:py-24">
    <!-- Texto -->
    <div class="lg:col-span-7 lg:order-1 flex flex-col justify-center text-center lg:text-left">
      <h1 class="text-hero text-ink-soft text-balance">
        🚀 Landing Page Económica y Rápida
      </h1>

      <p class="mt-5 max-w-2xl text-lg leading-relaxed text-ink-soft mx-auto lg:mx-0">
        <strong class="font-semibold text-ink">Landing page económica desde $70.000</strong>
        con diseño profesional, optimizada para Google y entrega en 48 horas. Ideal para captar
        clientes y generar conversiones efectivas. Experiencia en Astro.js y WordPress: combinación perfecta para rapidez y posicionamiento SEO.
      </p>

      <!-- Slider de mensajes -->
      <div class="mt-6 relative h-20 overflow-hidden mx-auto lg:mx-0 max-w-2xl">
        <div id="hero-slider">
          <p class="slider-item text-2xl font-bold text-orange-600 absolute w-full text-center lg:text-left transition-opacity duration-1000 ease-in-out opacity-100">
            ¿Quieres una landing rápida como esta? ⚡ Carga en menos de 1 segundo
          </p>
          <p class="slider-item text-2xl font-bold text-orange-600 absolute w-full text-center lg:text-left transition-opacity duration-1000 ease-in-out opacity-0">
            Tu puerta de entrada al éxito digital — Rápida, Económica y Profesional
          </p>
        </div>
      </div>

      <div class="mt-8 flex flex-wrap justify-center gap-4 lg:justify-start">
        <a href="#contacto" class="btn-primary">Solicitar Cotización</a>
        <a href="#precio" class="btn-secondary">Ver Precios</a>
      </div>
    </div>

    <!-- Imagen producto -->
    <div class="lg:col-span-5 lg:order-2 flex items-end justify-center">
      <Image
        src={heroCelu}
        alt="Diseño de Landing Pages Chile"
        width={560}
        height={720}
        quality={80}
        loading="eager"
        class="w-auto max-w-[70%] md:max-w-[60%] lg:max-w-full h-auto object-contain"
        format="webp"
      />
    </div>
  </div>
</section>

<script is:inline>
  (function () {
    const slides = document.querySelectorAll('.slider-item');
    let currentSlide = 0;

    function nextSlide() {
      // Ocultar slide actual
      slides[currentSlide].style.opacity = '0';
      
      // Siguiente slide
      currentSlide = (currentSlide + 1) % slides.length;
      
      // Mostrar nuevo slide
      slides[currentSlide].style.opacity = '1';
    }

    // Cambiar cada 4 segundos
    setInterval(nextSlide, 4000);
  })();
</script>
