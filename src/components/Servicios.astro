---
const servicios = [
  {
    title: 'Diseño de Landing Pages',
    desc: 'Creamos sitios web únicos, ligeros y optimizados, ideales para quienes buscan una solución básica pero profesional y efectiva.',
    alt: 'Diseño de Landing Pages',
    href: '/que-es-una-landing-page',
    icon: 'M3 12 12 4l9 8M5 10v10h14V10M9 20v-6h6v6',
  },
  {
    title: 'Landing Pages ultra rápidas',
    desc: 'Diseño de landing pages ultra rápidas con Astro JS en Chile. Optimiza la velocidad de carga y mejora la experiencia de usuario con soluciones personalizadas.',
    alt: 'Landing Pages ultra rápidas',
    href: '/que-es-una-landing-page',
    icon: 'M13 10V3L4 14h7v7l9-11h-7Z',
  },
  {
    title: 'Sitios Web Autoadministrables',
    desc: 'Implementamos sitios web que permiten a los usuarios gestionar fácilmente su contenido, utilizando tecnología como CMS WordPress.',
    alt: 'Sitios Web Autoadministrables',
    href: '/que-es-una-landing-page',
    icon: 'M12 6v6l4 2M12 2a10 10 0 1 0 10 10A10 10 0 0 0 12 2Z',
  },
  {
    title: 'Diseño de Logotipos Web',
    desc: 'Diseñamos tu logotipo de empresa en Adobe Illustrator, de manera rápida pero eficiente, con un enfoque en la usabilidad y la calidad para tu página web.',
    alt: 'Diseño de Logotipos Web',
    href: '/que-es-una-landing-page',
    icon: 'M7 8h10M7 12h10M7 16h6M5 4h14a2 2 0 0 1 2 2v12a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V6a2 2 0 0 1 2-2Z',
  },
  {
    title: 'Posicionamiento Web SEO',
    desc: 'Creamos páginas web con posicionamiento SEO en Chile, para que tu marca, servicios y/o productos sean visibles en la web, mediante el proceso de optimización de contenidos y enlaces.',
    alt: 'Posicionamiento Web SEO',
    href: '/que-es-una-landing-page',
    icon: 'm21 21-4.35-4.35M17 10a7 7 0 1 1-14 0 7 7 0 0 1 14 0Z',
  },
  {
    title: 'Sitios web Ecommerce',
    desc: 'Páginas web Tiendas online, ya sea con características de venta de productos o servicios, o como catálogo para que tus clientes conozcan tus productos y te contacten rápidamente.',
    alt: 'Sitios web Ecommerce',
    href: '/que-es-una-landing-page',
    icon: 'M3 3h2l.4 2M7 13h10l4-8H5.4M7 13 5.4 5M7 13l-1.68 3.39A1 1 0 0 0 6.22 18H17M9 21a1 1 0 1 0 0-2 1 1 0 0 0 0 2Zm8 0a1 1 0 1 0 0-2 1 1 0 0 0 0 2Z',
  },
];
---

<section id="servicios" class="section-padded bg-white">
  <div class="container-page">
    <div class="mx-auto max-w-2xl text-center">
      <h2 class="section-title text-balance">Te presentamos nuestros Servicios</h2>
    </div>

    <div class="mt-12 grid gap-6 md:grid-cols-2 lg:grid-cols-3">
      {
        servicios.map((s) => (
          <article class="group card reveal flex flex-col">
            <div class="mb-6 inline-flex h-14 w-14 items-center justify-center rounded-xl bg-brand-50 text-accent transition-colors group-hover:bg-accent group-hover:text-white">
              <svg
                xmlns="http://www.w3.org/2000/svg"
                class="h-7 w-7"
                viewBox="0 0 24 24"
                fill="none"
                stroke="currentColor"
                stroke-width="2"
                stroke-linecap="round"
                stroke-linejoin="round"
                aria-label={s.alt}
              >
                <path d={s.icon} />
              </svg>
            </div>
            <h3 class="text-xl font-bold text-ink mb-3">{s.title}</h3>
            <p class="text-ink-muted leading-relaxed flex-1">{s.desc}</p>
          </article>
        ))
      }
    </div>
  </div>
</section>
