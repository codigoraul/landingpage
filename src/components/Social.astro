const iconClass = variant === 'light' ? 'text-white' : 'text-ink';
const bgClass =
  variant === 'light'
    ? 'bg-white/10 hover:bg-white/20'
    : 'bg-brand-50 hover:bg-brand-100';
---

<ul class="flex items-center gap-2">
  {
    links.map((link) => (
      <li>
        <a
          href={link.href}
          target="_blank"
          rel="noopener noreferrer"
          aria-label={link.name}
          class={`inline-flex h-9 w-9 items-center justify-center rounded-full ${bgClass} ${iconClass} transition-all duration-200 hover:-translate-y-0.5`}
        >
          <svg
            xmlns="http://www.w3.org/2000/svg"
            width="14"
            height="14"
            viewBox="0 0 16 16"
            fill="currentColor"
            aria-hidden="true"
          >
            <path d={link.path} />
          </svg>
        </a>
      </li>
    ))
  }
</ul>
