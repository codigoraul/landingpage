---
import { Image } from 'astro:assets';
import fondoContacto from '../assets/images/fondo-contacto.jpg';
import Formulario from './Formulario.astro';
---

<section id="contacto" class="section-padded bg-brand-50/40">
  <div class="container-page grid gap-10 lg:grid-cols-12">
    <div class="lg:col-span-5 reveal">
      <Image
        src={fondoContacto}
        alt="Landing pages rápidas y optimizadas"
        width={640}
        height={720}
        quality={80}
        format="webp"
        loading="lazy"
        class="w-full h-full object-cover rounded-2xl shadow-card max-h-[640px]"
      />
    </div>

    <div class="lg:col-span-7 reveal">
      <div class="rounded-2xl bg-white p-6 sm:p-10 shadow-card">
        <h2 class="section-title mb-2">Envíanos tu consulta</h2>
        <p class="text-ink-muted mb-8">
          Completa el formulario y te contactaremos en menos de 24 horas.
        </p>
        <Formulario />
      </div>
    </div>
  </div>
</section>
