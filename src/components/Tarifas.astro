---
const baseMsg = (label: string) =>
  `https://api.whatsapp.com/send?phone=56961765268&text=${encodeURIComponent(
    `Hola, vi su contacto desde diseñopaginas.cl y necesito el plan ${label}:`
  )}`;

const planes = [
  {
    etiqueta: 'SI YA TIENES SITIO WEB',
    nombre: 'LANDING PAGE',
    precio: '$70.000',
    precioAnterior: '$120.000',
    promo: 'Sin mensualidad, pago único — ¡Ahorra $50.000!',
    destacado: false,
    ctaLabel: 'de Landing Page',
    features: [
      'Astro js (HTML), super rápida y segura',
      '1 Página u onepage',
      'Galería de imágenes hasta 12 imágenes',
      '4 Servicios o secciones',
      'Hero Principal Imagen y llamado a la acción',
      'Mapa de ubicación Google',
      '1 Formulario de contacto a su correo',
      'Botón de WhatsApp flotante',
      'Correos corporativos',
    ],
  },
  {
    etiqueta: 'LANDING PAGE — MEDIO',
    nombre: 'MEDIO',
    precio: '$140.000',
    precioAnterior: '$160.000',
    promo: 'Sin mensualidad, se paga una sola vez',
    destacado: true,
    ctaLabel: 'de la tarifa media',
    features: [
      'Hosting 2 GB por 1 año',
      'Astro js (HTML), super rápida y segura',
      '1 Página u onepage',
      'Galería de imágenes hasta 15 imágenes aprox.',
      '4 Servicios o secciones',
      'Hero Principal Imagen y llamado a la acción',
      'Mapa de ubicación Google',
      '1 Formulario de contacto a su correo',
      'Botón de WhatsApp flotante',
      'Correos corporativos',
    ],
  },
  {
    etiqueta: 'LANDING PAGE — AVANZADA',
    nombre: 'AVANZADA',
    precio: '$200.000',
    precioAnterior: '$250.000',
    promo: 'Sin mensualidad, pago único — ¡Ahorra $50.000!',
    destacado: false,
    ctaLabel: 'de la tarifa avanzada',
    features: [
      'Hosting 3 GB por 1 año',
      'Autoadministrable',
      '1 Página u onepage',
      'Galería de hasta 20 imágenes aprox.',
      '4 a 6 Servicios, texto y descripciones',
      'Slider principal de 4 imágenes',
      'Mapa de ubicación Google',
      '1 Formulario de contacto',
      'Correos corporativos ilimitados',
      'PDF instructivo con usuario y clave para editar su sitio web',
    ],
  },
];
---

<section id="precio" class="section-padded bg-brand-50/40">
  <div class="container-page">
    <div class="mx-auto max-w-2xl text-center">
      <h2 class="section-title text-balance">Nuestras Tarifas o Precios</h2>
      <p class="text-ink-muted text-lg">
        Planes pensados para cada necesidad. Sin mensualidades, pago único.
      </p>
    </div>

    <div class="mt-14 grid gap-8 md:grid-cols-2 lg:grid-cols-3">
      {
        planes.map((plan) => (
          <article
            class={`reveal relative flex flex-col rounded-2xl bg-white p-8 shadow-card transition-all duration-300 hover:-translate-y-1 hover:shadow-card-hover ${
              plan.destacado ? 'ring-2 ring-accent lg:scale-105' : ''
            }`}
          >
            {plan.destacado && (
              <span class="absolute -top-3 left-1/2 -translate-x-1/2 rounded-full bg-accent px-4 py-1 text-xs font-bold uppercase tracking-wider text-white">
                Más popular
              </span>
            )}

            <header class="mb-6 text-center">
              <p class="text-sm font-semibold uppercase tracking-widest text-accent">
                {plan.etiqueta}
              </p>
            </header>

            <div class="text-center">
              <div class="flex items-baseline justify-center gap-2">
                <span class="text-4xl font-extrabold text-ink">{plan.precio}</span>
                <span class="text-base text-ink-muted line-through">{plan.precioAnterior}</span>
              </div>
              <p class="mt-2 text-sm text-ink-muted">{plan.promo}</p>
            </div>

            <ul class="mt-8 space-y-3 flex-1">
              {plan.features.map((f) => (
                <li class="flex items-start gap-3 text-sm text-ink-soft">
                  <svg
                    class="mt-0.5 h-5 w-5 shrink-0 text-accent"
                    viewBox="0 0 24 24"
                    fill="none"
                    stroke="currentColor"
                    stroke-width="2.5"
                    aria-hidden="true"
                  >
                    <path stroke-linecap="round" stroke-linejoin="round" d="m5 13 4 4L19 7" />
                  </svg>
                  <span>{f}</span>
                </li>
              ))}
            </ul>

            <a
              href={baseMsg(plan.ctaLabel)}
              target="_blank"
              rel="noopener noreferrer"
              class={`mt-8 block w-full rounded-lg px-6 py-3 text-center font-semibold transition-all duration-300 ${
                plan.destacado
                  ? 'bg-accent text-white hover:bg-accent-hover'
                  : 'bg-ink text-white hover:bg-brand-900'
              }`}
            >
              Elegir este plan
            </a>
          </article>
        ))
      }
    </div>
  </div>
</section>
