---
import Social from './Social.astro';

const navItems = [
  { href: '/', label: 'Inicio' },
  { href: '#nosotros', label: 'Nosotros' },
  { href: '#servicios', label: 'Servicios' },
  { href: '#portafolio', label: 'Portafolio' },
  { href: '#precio', label: 'Precios' },
  { href: '#contacto', label: 'Contacto' },
];
---

<header id="site-header" class="sticky top-0 z-50 w-full transition-all duration-300">
  <!-- Top info bar -->
  <div id="top-bar" class="bg-brand-900 text-white text-sm transition-all duration-300">
    <div class="container-page flex flex-wrap items-center justify-between gap-3 py-2">
      <ul class="flex flex-wrap items-center gap-x-6 gap-y-1">
        <li>
          <a
            href="mailto:codigoraul@gmail.com"
            class="inline-flex items-center gap-2 hover:text-brand-200"
          >
            <svg class="h-4 w-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><rect x="3" y="5" width="18" height="14" rx="2"/><path d="m3 7 9 6 9-6"/></svg>
            codigoraul@gmail.com
          </a>
        </li>
        <li class="inline-flex items-center gap-2">
          <svg class="h-4 w-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><path d="M12 22s8-7 8-13a8 8 0 1 0-16 0c0 6 8 13 8 13Z"/><circle cx="12" cy="9" r="3"/></svg>
          Temuco / Santiago, Chile
        </li>
      </ul>
      <div class="flex items-center gap-4">
        <span class="hidden md:inline-flex items-center gap-2">
          <svg class="h-4 w-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><circle cx="12" cy="12" r="10"/><path d="M12 6v6l4 2"/></svg>
          Lunes a sábado: 24hrs
        </span>
        <Social variant="light" />
      </div>
    </div>
  </div>

  <!-- Main nav -->
  <div id="main-nav" class="bg-white shadow-sm border-b border-gray-100 transition-all duration-300">
    <div class="container-page flex items-center justify-between py-3">
      <a href="./" class="inline-flex items-center" aria-label="Ir al inicio">
        <img
          src="./images/logo/diseno-web-logo.svg"
          width="293"
          height="64"
          alt="logo Diseño web chile"
          class="h-16 w-auto"
        />
      </a>

      <nav class="hidden xl:block" aria-label="Principal">
        <ul class="flex items-center gap-8">
          {
            navItems.map((item) => (
              <li>
                <a
                  href={item.href}
                  class="text-ink font-medium hover:text-accent transition-colors"
                >
                  {item.label}
                </a>
              </li>
            ))
          }
        </ul>
      </nav>

      <div class="flex items-center gap-3">
        <a href="#contacto" class="btn-header hidden sm:inline-flex">
          Formulario de contacto
        </a>
        <button
          type="button"
          id="menu-toggle"
          aria-label="Abrir menú"
          aria-controls="mobile-menu"
          aria-expanded="false"
          class="xl:hidden inline-flex h-10 w-10 items-center justify-center rounded-lg text-ink hover:bg-gray-100 transition-colors"
        >
          <svg class="h-6 w-6" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24" aria-hidden="true">
            <path stroke-linecap="round" stroke-linejoin="round" d="M4 6h16M4 12h16M4 18h16" />
          </svg>
        </button>
      </div>
    </div>
  </div>
</header>

<!-- Mobile menu overlay -->
<div
  id="mobile-menu"
  class="fixed inset-0 z-[60] hidden bg-white/95 backdrop-blur-sm xl:hidden"
  role="dialog"
  aria-modal="true"
  aria-label="Menú de navegación"
>
  <div class="flex h-full flex-col">
    <div class="flex items-center justify-between border-b border-gray-100 px-6 py-4">
      <a href="./" aria-label="Ir al inicio">
        <img src="./images/logo/diseno-web-logo.svg" width="140" height="37" alt="logo" class="h-9 w-auto" />
      </a>
      <button
        type="button"
        id="menu-close"
        aria-label="Cerrar menú"
        class="inline-flex h-10 w-10 items-center justify-center rounded-lg text-ink hover:bg-gray-100"
      >
        <svg class="h-6 w-6" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24" aria-hidden="true">
          <path stroke-linecap="round" stroke-linejoin="round" d="M6 18 18 6M6 6l12 12" />
        </svg>
      </button>
    </div>
    <nav class="flex-1 overflow-y-auto px-6 py-8" aria-label="Móvil">
      <ul class="flex flex-col gap-2">
        {
          navItems.map((item) => (
            <li>
              <a
                href={item.href}
                class="mobile-nav-link block rounded-lg px-4 py-3 text-lg font-semibold text-ink hover:bg-brand-50 hover:text-accent"
              >
                {item.label}
              </a>
            </li>
          ))
        }
      </ul>
      <a href="#contacto" class="btn-primary mobile-nav-link mt-6 w-full">
        Formulario de contacto
      </a>
    </nav>
  </div>
</div>

<script is:inline>
  (function () {
    const toggle = document.getElementById('menu-toggle');
    const close = document.getElementById('menu-close');
    const menu = document.getElementById('mobile-menu');
    if (!toggle || !close || !menu) return;

    function open() {
      menu.classList.remove('hidden');
      toggle.setAttribute('aria-expanded', 'true');
      document.body.style.overflow = 'hidden';
    }
    function hide() {
      menu.classList.add('hidden');
      toggle.setAttribute('aria-expanded', 'false');
      document.body.style.overflow = '';
    }

    toggle.addEventListener('click', open);
    close.addEventListener('click', hide);
    menu.querySelectorAll('.mobile-nav-link').forEach(function (link) {
      link.addEventListener('click', hide);
    });
    document.addEventListener('keydown', function (e) {
      if (e.key === 'Escape' && !menu.classList.contains('hidden')) hide();
    });
  })();
</script>

<script is:inline>
  (function () {
    const topBar = document.getElementById('top-bar');
    const mainNav = document.getElementById('main-nav');
    const header = document.getElementById('site-header');
    let lastScroll = 0;

    window.addEventListener('scroll', function () {
      const currentScroll = window.pageYOffset;

      if (currentScroll > 50) {
        // Ocultar top bar
        if (topBar) {
          topBar.style.maxHeight = '0';
          topBar.style.overflow = 'hidden';
          topBar.style.opacity = '0';
        }
        // Hacer translúcido el main nav
        if (mainNav) {
          mainNav.style.backgroundColor = 'rgba(255, 255, 255, 0.85)';
          mainNav.style.backdropFilter = 'blur(10px)';
          mainNav.style.webkitBackdropFilter = 'blur(10px)';
        }
      } else {
        // Mostrar top bar
        if (topBar) {
          topBar.style.maxHeight = '100px';
          topBar.style.overflow = 'visible';
          topBar.style.opacity = '1';
        }
        // Fondo sólido
        if (mainNav) {
          mainNav.style.backgroundColor = 'rgb(255, 255, 255)';
          mainNav.style.backdropFilter = 'none';
          mainNav.style.webkitBackdropFilter = 'none';
        }
      }

      lastScroll = currentScroll;
    });
  })();
</script>
