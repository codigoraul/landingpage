---
const SITE_KEY = '6Lc1VBsTAAAAAJ94jzAhw1B3-Cgi3G6TRnoeejLF';
---

<form
  id="contactForm"
  method="POST"
  class="space-y-5"
  data-sitekey={SITE_KEY}
  novalidate
>
  <div class="grid gap-5 md:grid-cols-2">
    <div>
      <label for="f-nombre" class="sr-only">Nombre</label>
      <input
        id="f-nombre"
        type="text"
        name="nombre"
        placeholder="Nombre"
        required
        autocomplete="name"
        class="w-full h-12 rounded-lg border border-gray-200 bg-white px-4 text-base text-ink placeholder:text-gray-400 focus:border-accent focus:ring-4 focus:ring-accent/10 focus:outline-none transition"
      />
    </div>
    <div>
      <label for="f-email" class="sr-only">Email</label>
      <input
        id="f-email"
        type="email"
        name="email"
        placeholder="Email"
        required
        autocomplete="email"
        class="w-full h-12 rounded-lg border border-gray-200 bg-white px-4 text-base text-ink placeholder:text-gray-400 focus:border-accent focus:ring-4 focus:ring-accent/10 focus:outline-none transition"
      />
    </div>
    <div>
      <label for="f-fono" class="sr-only">Teléfono</label>
      <input
        id="f-fono"
        type="tel"
        name="fono"
        placeholder="Teléfono"
        required
        autocomplete="tel"
        class="w-full h-12 rounded-lg border border-gray-200 bg-white px-4 text-base text-ink placeholder:text-gray-400 focus:border-accent focus:ring-4 focus:ring-accent/10 focus:outline-none transition"
      />
    </div>
    <div>
      <label for="f-presupuesto" class="sr-only">Plan</label>
      <select
        id="f-presupuesto"
        name="presupuesto"
        required
        class="w-full h-12 rounded-lg border border-gray-200 bg-white px-4 text-base text-ink focus:border-accent focus:ring-4 focus:ring-accent/10 focus:outline-none transition appearance-none bg-[url('data:image/svg+xml;charset=utf-8,%3Csvg%20xmlns=%22http://www.w3.org/2000/svg%22%20width=%2216%22%20height=%2216%22%20viewBox=%220%200%2024%2024%22%20fill=%22none%22%20stroke=%22%23666%22%20stroke-width=%222%22%20stroke-linecap=%22round%22%20stroke-linejoin=%22round%22%3E%3Cpolyline%20points=%226%209%2012%2015%2018%209%22%3E%3C/polyline%3E%3C/svg%3E')] bg-no-repeat bg-[right_1rem_center] pr-10"
      >
        <option value="">Selecciona un plan</option>
        <option value="Si ya tienes sitio web">Si ya tienes sitio web — $70.000</option>
        <option value="Landing Page - Medio">Landing Page Medio — $140.000</option>
        <option value="Landing Page - Avanzada">Landing Page Avanzada — $200.000</option>
      </select>
    </div>
  </div>

  <div>
    <label for="f-mensaje" class="sr-only">Mensaje</label>
    <textarea
      id="f-mensaje"
      name="mensaje"
      placeholder="Mensaje"
      required
      rows="5"
      class="w-full rounded-lg border border-gray-200 bg-white px-4 py-3 text-base text-ink placeholder:text-gray-400 focus:border-accent focus:ring-4 focus:ring-accent/10 focus:outline-none transition resize-y min-h-[120px]"
    ></textarea>
  </div>

  <div id="recaptcha-container" class="flex justify-start"></div>

  <div class="flex flex-col sm:flex-row sm:items-center gap-4">
    <button type="submit" class="btn-primary min-w-[200px]">
      Enviar mensaje
    </button>
    <p class="text-xs text-ink-muted">
      Al enviar aceptas que te contactemos por los medios indicados.
    </p>
  </div>

  <div
    id="formMessage"
    class="hidden rounded-lg p-4 text-sm"
    role="status"
    aria-live="polite"
  ></div>
</form>

<script>
  const form = document.getElementById('contactForm') as HTMLFormElement | null;
  const formMessage = document.getElementById('formMessage');
  const recaptchaContainer = document.getElementById('recaptcha-container');
  const SITE_KEY = form?.dataset.sitekey || '';
  let recaptchaLoaded = false;
  let recaptchaWidget: number | null = null;

  function showMessage(ok: boolean, text: string) {
    if (!formMessage) return;
    formMessage.classList.remove('hidden', 'bg-green-50', 'text-green-800', 'bg-red-50', 'text-red-800');
    if (ok) {
      formMessage.classList.add('bg-green-50', 'text-green-800');
      formMessage.textContent = '✓ ' + text;
    } else {
      formMessage.classList.add('bg-red-50', 'text-red-800');
      formMessage.textContent = '⚠ ' + text;
    }
  }

  function loadRecaptcha() {
    if (recaptchaLoaded || !recaptchaContainer) return;
    recaptchaLoaded = true;
    const script = document.createElement('script');
    script.src = 'https://www.google.com/recaptcha/api.js?render=explicit';
    script.async = true;
    script.defer = true;
    script.onload = () => {
      // @ts-ignore
      (window as any).grecaptcha?.ready(() => {
        try {
          // @ts-ignore
          recaptchaWidget = (window as any).grecaptcha.render('recaptcha-container', {
            sitekey: SITE_KEY,
          });
        } catch (err) {
          console.error('reCAPTCHA render error', err);
        }
      });
    };
    document.head.appendChild(script);
  }

  form?.querySelectorAll('input, textarea, select').forEach((el) => {
    el.addEventListener('focus', loadRecaptcha, { once: true });
  });

  form?.addEventListener('submit', async (e) => {
    e.preventDefault();
    // @ts-ignore
    const token = (window as any).grecaptcha?.getResponse(recaptchaWidget);
    if (!token) {
      showMessage(false, 'Por favor, completa el reCAPTCHA antes de enviar el mensaje.');
      return;
    }
    const fd = new FormData(form);
    fd.append('g-recaptcha-response', token);
    try {
      const res = await fetch('/procesar-formulario.php', { method: 'POST', body: fd });
      const data = await res.json().catch(() => ({ error: 'Respuesta inválida del servidor.' }));
      if (data.success) {
        showMessage(true, '¡Mensaje enviado correctamente! Te responderemos a la brevedad.');
        form.reset();
        // @ts-ignore
        if (recaptchaWidget !== null) (window as any).grecaptcha.reset(recaptchaWidget);
      } else {
        showMessage(false, data.error || 'Error al enviar el mensaje.');
      }
    } catch (err) {
      showMessage(false, 'Error de conexión. Por favor, intenta nuevamente.');
    }
  });
</script>
