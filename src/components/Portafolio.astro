---
import { Image } from 'astro:assets';
import arqueocat from '../../public/images/portafolio/arqueocat.jpg';
import animaldoc from '../../public/images/portafolio/animaldoc.jpg';
import apurolegal from '../../public/images/portafolio/apurolegal.jpg';
import asesorialimentos from '../../public/images/portafolio/asesorialimentos.jpg';
import bestproperty from '../../public/images/portafolio/bestproperty.jpg';
import ceromultas from '../../public/images/portafolio/ceromultas.jpg';
import comprobe from '../../public/images/portafolio/comprobe.jpg';
import veterinaria from '../../public/images/portafolio/landing-vet.jpg';

const proyectos = [
  { img: veterinaria, url: 'https://diseñopaginas.cl/portafolio-landing/veterinaria/', title: 'www.veterinaria-landing.cl', rubro: 'Diseño web Veterinaria', alt: 'Diseño web para veterinarias en Chile' },
  { img: arqueocat, url: 'https://arqueocat.cl', title: 'www.arqueocat.cl', rubro: 'Diseño web Arqueología', alt: 'Diseño web para arqueólogos en Chile' },
  { img: animaldoc, url: 'https://animaldoc.cl', title: 'www.animaldoc.cl', rubro: 'Diseño web Veterinaria', alt: 'Diseño web para veterinarias en Chile' },
  { img: apurolegal, url: 'https://apurolegal.cl', title: 'www.apurolegal.cl', rubro: 'Diseño web Abogados', alt: 'Diseño web para abogados en Chile' },
  { img: asesorialimentos, url: 'https://asesorialimento.cl', title: 'www.asesorialimento.cl', rubro: 'Diseño web Alimentos', alt: 'Diseño web para empresas de alimentos en Chile' },
  { img: bestproperty, url: 'https://bestproperty.cl', title: 'www.bestproperty.cl', rubro: 'Diseño web Propiedades', alt: 'Diseño web para corredoras de propiedades en Chile' },
  { img: ceromultas, url: 'https://ceromultas.cl', title: 'www.ceromultas.cl', rubro: 'Diseño web Abogados', alt: 'Diseño web para servicios legales en Chile' },
  { img: comprobe, url: 'https://comprobe.cl', title: 'www.comprobe.cl', rubro: 'Diseño web Empresa', alt: 'Diseño web para empresas en Chile' },
];
---

<section id="portafolio" class="section-padded bg-white">
  <div class="container-page">
    <div class="grid gap-8 lg:grid-cols-12 lg:items-end">
      <div class="lg:col-span-5">
        <h2 class="section-title text-balance">Nuestro portafolio de proyectos web</h2>
      </div>
      <div class="lg:col-span-7 lg:pl-12">
        <p class="text-ink-muted text-lg">
          Trabajamos con empresas de diversos sectores, así como con emprendedores que buscan
          destacar en el mercado digital chileno.
        </p>
        <p class="text-ink-muted text-lg mt-3">
          Sea cual sea el tamaño de tu proyecto, estamos aquí para llevar tu presencia en línea al
          siguiente nivel. ¡Contáctanos para una cotización personalizada!
        </p>
      </div>
    </div>

    <!-- Banner oferta -->
    <div class="mt-10 rounded-2xl border-l-4 border-accent bg-brand-50 p-6 text-center">
      <p class="text-lg font-semibold text-brand-900">
        🎉 OFERTA ESPECIAL: $70.000.- para empresas que ya cuenten con una página web
      </p>
    </div>

    <!-- Grid -->
    <div class="mt-12 grid gap-5 sm:grid-cols-2 lg:grid-cols-3 xl:grid-cols-4">
      {
        proyectos.map((p) => (
          <a
            href={p.url}
            target="_blank"
            rel="noopener noreferrer"
            class="group relative block overflow-hidden rounded-2xl shadow-card aspect-[3/2] reveal"
            aria-label={`Ver ${p.title}`}
          >
            <Image
              src={p.img}
              alt={p.alt}
              width={600}
              height={400}
              quality={80}
              format="webp"
              loading="lazy"
              class="absolute inset-0 h-full w-full object-cover transition-transform duration-500 group-hover:scale-105"
            />
            <div class="absolute inset-0 bg-gradient-to-t from-ink/90 via-ink/30 to-transparent"></div>
            <div class="absolute inset-x-0 bottom-0 p-5 text-white translate-y-2 opacity-90 group-hover:translate-y-0 group-hover:opacity-100 transition-all duration-300">
              <h3 class="text-base md:text-lg font-bold leading-tight">{p.title}</h3>
              <p class="text-sm text-white/90 mt-1">{p.rubro}</p>
            </div>
          </a>
        ))
      }
    </div>
  </div>
</section>
